APP_ENV=development
AGENT_HTTP_PORT=8000

AGENT_PRIMARY_MODEL=qwen2.5:7b
AGENT_PRIMARY_BASE_URL=http://host.docker.internal:11434/v1
AGENT_PRIMARY_API_KEY=ollama

AGENT_FALLBACK_MODEL=qwen2.5:7b
AGENT_FALLBACK_BASE_URL=http://host.docker.internal:11434/v1
AGENT_FALLBACK_API_KEY=ollama

AGENT_INPUT_COST_PER_1K=0.0
AGENT_OUTPUT_COST_PER_1K=0.0
AGENT_TENANT_DAILY_BUDGET_USD=1.0

AGENT_MODEL_CONTEXT_WINDOW=8192
AGENT_CONTEXT_COMPACT_THRESHOLD_RATIO=0.85
AGENT_MODEL_RETRIES=2
AGENT_RETRY_BASE_DELAY_S=0.35
AGENT_RETRY_MAX_JITTER_S=0.25
AGENT_EVENT_WORKER_SHUTDOWN_TIMEOUT_S=30
AGENT_PROACTIVE_CRON_INTERVAL_S=30
AGENT_PROACTIVE_TASK_MAX_STEPS=3
AGENT_PROACTIVE_STM_WARNING_THRESHOLD=80
